# Stacks network: mainnet | testnet | devnet
STACKS_NETWORK=testnet

# Stacks API URL (leave blank for default based on STACKS_NETWORK)
# STACKS_API_URL=https://api.testnet.hiro.so

# 12- or 24-word BIP39 mnemonic (same wallet used to deploy contracts — ACN address = deployer)
ACN_MNEMONIC=
# Optional BIP39 passphrase
# ACN_MNEMONIC_PASSPHRASE=

# Deployer address that deployed file-registry and acn-payments contracts
CONTRACT_DEPLOYER=

# Secret used to encrypt AES keys at rest (min 32 chars)
KEY_ENCRYPTION_SECRET=

# x402 facilitator URL (default: https://x402-backend-7eby.onrender.com)
X402_FACILITATOR_URL=https://x402-backend-7eby.onrender.com

# IPFS pinning provider: pinata | local
IPFS_PROVIDER=local

# Pinata JWT (required if IPFS_PROVIDER=pinata)
# Get one at https://app.pinata.cloud/developers/api-keys
# PINATA_JWT=

# Server
PORT=3100
